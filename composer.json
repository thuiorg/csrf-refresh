{
    "name": "thuiorg/csrf-refresh",
    "description": "Automatic CSRF token refresh for Laravel applications to prevent token expiration on long-lived pages",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "csrf",
        "token",
        "refresh",
        "session",
        "security"
    ],
    "homepage": "https://github.com/thuiorg/csrf-refresh",
    "authors": [
        {
            "name": "Tommy Hui",
            "email": "thui@thui.org"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "thuiorg\\CsrfRefresh\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "thuiorg\\CsrfRefresh\\CsrfRefreshServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
